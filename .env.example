# Copy this file to .env and fill in real values.
# In CI, these are provided via GitHub Actions secrets (see .github/workflows/playwright.yml).

# Credentials used for both UI login and API login (/api/accounts/login/)
TEST_EMAIL=test@email.com
TEST_PASSWORD=examplepassword

# UI application host
UI_BASE_URL=https://example.com

# API host
API_BASE_URL=https://example.api.com
